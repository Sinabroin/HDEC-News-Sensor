# HDEC Executive Radar — Day-1 환경 설정 예시
# 사용법: cp .env.example .env
# 이 파일은 commit 대상이며, .env는 절대 commit하지 않는다 (.gitignore에 포함).

# 기본 실행 모드. Day-1 데모는 반드시 mock으로 실행한다.
# mock 모드에서는 외부 네트워크 호출이 0건이며 API key가 전혀 필요 없다.
APP_MODE=mock

# 뉴스 수집 모드 (P0-C1). 기본 mock = 네트워크 0건 / 비밀값 0건.
# live = 공개 RSS(Google News RSS)에서 실제 뉴스 메타데이터를 수집한다.
#   - 인증/비밀값이 전혀 필요 없다 (공개 피드).
#   - 본문 전문은 저장하지 않는다 (제목/요약/출처/링크/시각만).
#   - 수집 실패 시 가짜 live를 만들지 않고 mock으로 fallback한다.
NEWS_MODE=mock

# 시장지표(macro) 모드 (P0-C2). NEWS_MODE와 독립적. 기본 mock = 네트워크 0건 / 비밀값 0건.
# live = 공개 시세 API(Yahoo Finance chart 등, data/live_macro_sources.json)에서 실제 시장지표를 수집한다.
#   - 인증/비밀값(API key)이 전혀 필요 없다 (공개 무인증 엔드포인트, 공급자 교체 가능).
#   - 출처·기준시각·stale(지연) 플래그를 함께 표기한다.
#   - 수집 실패/0건 시 가짜 값으로 채우지 않고 unavailable로 강등한다.
#   - 표시 레이어는 macro_data_mode=live일 때만 수치를 노출한다 (가짜 시세 금지).
MACRO_MODE=mock

# (선택) 같은 publish 실행에서 리포트·다이제스트가 동일 시장지표 snapshot을 쓰도록 공유하는
# 1회용 파일 경로. 지정하면 먼저 도는 프로세스가 fetch한 snapshot을 파일로 남기고 다음 프로세스가
# 재fetch 없이 읽어 값이 어긋나지 않는다. 미설정이면 프로세스별로 각자 fetch한다. 저장소에
# commit하지 않는 휘발 경로를 쓴다(CI는 runner temp). 비밀값 아님.
# MACRO_SNAPSHOT_FILE=/tmp/hdec_macro_snapshot.json

# SQLite 파일 경로 (선택, 기본값: 저장소 루트의 radar.db)
# DB_PATH=radar.db

# P0-B(RSS/Naver/OpenAI/Teams) 관련 키는 P0-A 통과 후 P0-B를 구현할 때만 추가한다.
# Day-1에서 X 관련 키는 어떤 이름으로도 추가하지 않는다 (rules.md §1, §4).
